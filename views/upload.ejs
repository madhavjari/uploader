<!DOCTYPE html>
<html lang="en">
  <%- include("./partials/head.ejs") %>
  <body class="page">
    <main class="upload-shell">
      <section class="upload-panel">
        <a class="brand auth-brand" href="/">
          <span class="brand-mark">FU</span>
          <span>File Uploader</span>
        </a>
        <div class="upload-heading">
          <p class="eyebrow">Upload</p>
          <h1>Choose a file to store locally.</h1>
          <p>Your selected file will be saved by the uploader service.</p>
        </div>
        <form action="/upload" method="post" enctype="multipart/form-data">
          <label class="file-field" for="avatar">
            <span>Select file</span>
            <span class="file-dropzone">
              <input id="avatar" type="file" name="avatar" />
            </span>
          </label>
          <div class="upload-actions">
            <button class="button button-primary" type="submit">Upload file</button>
            <a class="button button-secondary" href="/">Back home</a>
          </div>
        </form>
      </section>
    </main>
  </body>
</html>
