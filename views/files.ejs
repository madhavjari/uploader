<!DOCTYPE html>
<html lang="en">
  <%- include("./partials/head.ejs") %>
  <body class="page app-page">
    <main class="app-shell">
      <section class="app-panel">
        <nav class="topbar app-topbar" aria-label="Primary">
          <a class="brand" href="/">
            <span class="brand-mark">FU</span>
            <span>File Uploader</span>
          </a>
          <div class="nav-actions">
            <a class="button button-secondary" href="/<%= username %>">Folders</a>
            <a class="button button-primary" href="/<%= username %>/<%= id %>/upload">
              Upload a file
            </a>
          </div>
        </nav>

        <header class="app-heading">
          <p class="eyebrow">Folder</p>
          <h1>All files</h1>
          <p>Review files stored in this folder and add more when needed.</p>
        </header>

        <% if(allFiles && allFiles.length) { %>
          <div class="file-list">
            <% allFiles.forEach((file) =>{ %>
              <article class="file-row">
                <div class="file-icon" aria-hidden="true"></div>
                <div class="file-main">
                  <h2><%= file.name %></h2>
                  <dl class="file-meta">
                    <div>
                      <dt>Size</dt>
                      <dd><%= file.size %> kB</dd>
                    </div>
                    <div>
                      <dt>Uploaded</dt>
                      <dd><%= file.timestamp %></dd>
                    </div>
                  </dl>
                </div>
                <button
                  class="button button-danger-soft button-small delete-button"
                  type="button"
                  aria-label="Delete file <%= file.name %>"
                  data-dialog="delete-<%= file.id %>"
                >
                  Delete
                </button>
              </div>

              <dialog class="delete-modal" id="delete-<%= file.id %>">
                <form
                  class="modal-card delete-card"
                  action="/<%= username %>/<%= id %>/<%= file.id %>/delete"
                  method="post"
                >
                  <div class="modal-heading">
                    <p class="eyebrow">Confirm delete</p>
                    <h2>Delete this file</h2>
                  </div>
                  <p class="message-body">
                    This removes the file and cannot be recovered.
                  </p>
                  <div class="modal-actions">
                    <button
                      class="button button-secondary delete-close-modal"
                      type="button"
                    >
                      Cancel
                    </button>
                    <button class="button button-danger" type="submit">
                      Delete
                    </button>
                  </div>
                </form>
              </dialog>
            </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <h2>No files yet</h2>
            <p>Upload the first file to start filling this folder.</p>
            <a class="button button-primary" href="/<%= username %>/<%= id %>/upload">
              Upload a file
            </a>
          </div>
        <% } %>
      </section>
    </main>
  </body>
  <script>
    const deleteButtons = document.querySelectorAll(".delete-button");
    const deleteCloseButtons = document.querySelectorAll(".delete-close-modal");
    deleteButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const dialog = document.getElementById(button.dataset.dialog);
        dialog.showModal();
      });
    });
    deleteCloseButtons.forEach((button) => {
      button.addEventListener("click", () => {
        button.closest("dialog").close();
      });
    });
  </script>
</html>
