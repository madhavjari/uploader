<!DOCTYPE html>
<html lang="en">
  <%- include("./partials/head.ejs") %>
  <body class="page auth-page">
    <main class="auth-shell">
      <section class="auth-card">
        <a class="brand auth-brand" href="/">
          <span>File Uploader</span>
        </a>
        <form class="form-stack" action="/login" method="POST">
          <div class="field">
            <label for="username">Username</label>
            <input
              id="username"
              type="text"
              name="username"
              required
              minlength="3"
              maxlength="30"
              autocomplete="username"
            />
          </div>
          <div class="field">
            <label for="password">Password</label>
            <input
              id="password"
              type="password"
              name="password"
              required
              minlength="8"
              maxlength="30"
              autocomplete="current-password"
            />
          </div>
          <button class="button button-primary button-full" type="submit">
            Log in
          </button>
        </form>
        <p class="auth-switch">
          New here? <a href="/sign-up">Create an account</a>
        </p>
      </section>
    </main>
  </body>
</html>
