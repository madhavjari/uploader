<!DOCTYPE html>
<html lang="en">
  <%- include("./partials/head.ejs") %>
  <body>
    <button class="new-folder">Create a folder</button>
    <a class="nav-link" href="/log-out">Log out</a>
    <% if (error) { %>
        <h3><%= error %></h3>
    <% } %>
    <% folderName.forEach((folder) =>{ %>
      <div>
        <a href="<%= username %>/<%= folder.id %>"><%= folder.name %></a>
        <button class="edit-button">Edit</button>
        <button
        class="icon-button delete-button"
        type="button"
        aria-label="Delete message"
        data-dialog="delete-<%= folder.id %>"
      >
        Delete
      </button>
      <dialog class="delete-modal" id="delete-<%= folder.id %>">
        <form
          class="modal-card delete-card"
          action="/<%= username %>/<%= folder.id %>/delete"
          method="post"
        >
          <div class="modal-heading">
            <p class="eyebrow">Confirm delete</p>
            <h2>Delete this folder and content within?</h2>
          </div>
          <p class="message-body">
            This removes all the files from the folder.
          </p>
          <div class="modal-actions">
            <button
              class="button button-ghost delete-close-modal"
              type="button"
            >
              Cancel
            </button>
            <button class="button button-danger" type="submit">
              Delete
            </button>
          </div>
        </form>
      </dialog>
</div>
    <% }) %>
    <dialog class="new-folder-dialog">
      <form action="/<%= username %>" method="post">
        <button class="close-button">x</button>
        <label for="folder">Folder name</label>
        <input
          type="text"
          required
          minlength="2"
          maxlength="15"
          name="folder"
        />
        <button type="submit">Create</button>
        <button class="close-button">Cancel</button>
      </form>
    </dialog>
  </body>
  <script>
    const addFolderButton = document.querySelector(".new-folder");
    const newDialog = document.querySelector(".new-folder-dialog");
    const deleteButtons = document.querySelectorAll(".delete-button");
    const deleteCloseButtons = document.querySelectorAll(".delete-close-modal");
    deleteButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const dialog = document.getElementById(button.dataset.dialog);
        dialog.showModal();
      });
    });

    deleteCloseButtons.forEach((button) => {
      button.addEventListener("click", () => {
        button.closest("dialog").close();
      });
    });
    addFolderButton.addEventListener("click", () => {
      newDialog.showModal();
    });

    const closeButton = document.querySelectorAll(".close-button");
    closeButton.forEach((button) => {
      button.addEventListener("click", () => {
      newDialog.close();
      })
    });
  </script>
</html>
